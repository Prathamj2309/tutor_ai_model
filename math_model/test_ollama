import requests
import json
import time

def test_sft_aligned_model():
    url = "http://localhost:11434/api/generate"
    model_name = "custom_jee_solver"
    
    # 1. The overarching static system prompt
    system_prompt = """You are an expert mathematical reasoning AI. Your task is to solve complex mathematical problems accurately.

You must strictly adhere to the following formatting protocol for every single response:
1.  **Reasoning Phase:** You must begin your response by outlining your step-by-step logical deductions, calculations, and verifications. This entire thought process MUST be enclosed exactly within <think> and </think> tags.
2.  **Final Answer Phase:** Immediately after the </think> tag, you must output your final answer enclosed in a LaTeX \\boxed{} macro.
3.  **Strict Constraint:** Follow the specific extraction instructions provided in the user prompt (e.g., outputting ONLY the option letter or ONLY the integer inside the box). Do not output any conversational text, introductory statements, or explanations outside of the <think> tags and the final \\boxed{} output."""

    # 2. The exact user template generated by your SFT formatting function
    user_prompt = """This is a numerical question. Respond EXACTLY with strictly the integer mathematical value enclosed in a LaTeX box (e.g., \\boxed{42}).

Respond EXACTLY in this format:
<think>
step-by-step reasoning
</think>
\\boxed{final answer}

Question:
[Diagram Translation]: A block of mass 2kg is sliding down a frictionless inclined plane of angle 30 degrees. 
Calculate the acceleration of the block down the incline. Use g = 10 m/s^2."""

    payload = {
        "model": model_name,
        "system": system_prompt,
        "prompt": user_prompt,
        "stream": False,
        "options": {
            "temperature": 0.1 # Low temperature for logical consistency
        }
    }
    
    print(f"Sending formatted prompt to '{model_name}'...\n")
    start_time = time.time()
    
    try:
        response = requests.post(url, json=payload)
        
        if response.status_code == 200:
            result = response.json()
            generation = result.get("response", "")
            
            print("=== MODEL OUTPUT ===")
            print(generation)
            print("====================")
            
            # Validation checks to see if the model learned the SFT format
            print("\n=== FORMAT VALIDATION ===")
            if "<think>" in generation and "</think>" in generation:
                print("[PASS] Think tags present.")
            else:
                print("[FAIL] Missing <think> or </think> tags.")
                
            if "\\boxed{" in generation:
                print("[PASS] LaTeX boxed answer present.")
            else:
                print("[FAIL] Missing \\boxed{} format.")
                
        else:
            print(f"API Error: {response.status_code}\n{response.text}")
            
    except requests.exceptions.ConnectionError:
        print("Fatal Error: Could not connect to localhost:11434. Ensure Ollama is running.")

if __name__ == "__main__":
    test_sft_aligned_model()